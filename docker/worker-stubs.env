# External integrations the worker references via @Value with no default.
# We don't run those services locally, so just feed Spring stub values that
# satisfy startup. Behaviour-wise:
#   - GLIMPS_ENABLED=false (in compose env) disables the Glimps code path
#   - the *MOCK*  flags trigger the offline mocks already in the worker
BUCKET_ALLOWLIST=*
CHECK_FILE_PATH=/tmp/ft-check
GLIMPS_AUTH_TOKEN_KEY=X-Auth-Token
GLIMPS_AUTH_TOKEN_VALUE=disabled
GLIMPS_CHECK_URL=http://localhost/glimps-disabled/check
GLIMPS_SCAN_URL=http://localhost/glimps-disabled/scan
GLIMPS_KNOWNCODE=4001,5001,5000
OSMOSE_MOCK_DEFAULTVALUE=true
RESANA_MOCK_DEFAULTVALUE=true
RIZOMO_MOCK_DEFAULTVALUE=true
RIZOMO_APPLICATION=ft-local-dev
REF_DOMAIN_TOKEN=disabled
REF_DOMAIN_URL=http://localhost/ref-disabled/domain
REF_STAT_TOKEN=disabled
REF_STAT_HEADER=X-Stat
REF_STAT_URL=http://localhost/ref-disabled/stat
